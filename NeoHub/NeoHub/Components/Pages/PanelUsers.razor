@page "/panel-users"
@using NeoHub.Services
@using NeoHub.Services.Models
@using NeoHub.Services.Settings
@using DSC.TLink.ITv2.MediatR
@using DSC.TLink.ITv2.Enumerations
@using Microsoft.Extensions.Options
@inject IPanelUserService UserService
@inject IPanelStateService PanelState
@inject IITv2SessionManager SessionManager
@inject ISessionMonitor SessionMonitor
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager Navigation
@inject IOptionsMonitor<PanelConnectionsSettings> ConnectionSettings
@implements IDisposable

<PageTitle>Panel Users</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">

    @if (_sessionId is null)
    {
        <MudAlert Severity="Severity.Warning">No active panel session.</MudAlert>
    }
    else
    {
        @* ── Header ── *@
        <MudPaper Class="pa-3 mb-4">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                <MudStack Row="true" Spacing="4" AlignItems="AlignItems.Center">
                    <MudIcon Icon="@Icons.Material.Filled.Key" Size="Size.Large" />
                    <div>
                        <MudText Typo="Typo.h5">Panel Users</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            Session: @_sessionId
                            @if (_session?.UsersLastReadAt is not null)
                            {
                                <text> · Read @_session.UsersLastReadAt.Value.ToLocalTime().ToString("HH:mm:ss")</text>
                            }
                            @if (_session?.MaxUsers > 0)
                            {
                                <text> · @_session.MaxUsers user slots</text>
                            }
                            @if (_session?.MaxPartitions > 0)
                            {
                                <text> · @_session.MaxPartitions partitions</text>
                            }
                        </MudText>
                    </div>
                </MudStack>
                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                    <MudSwitch T="bool" Label="Show codes" @bind-Value="_revealCodes" Color="Color.Primary" />
                    <MudSwitch T="bool" Label="Show inactive" @bind-Value="_showInactive" Color="Color.Primary" />
                    <MudButton Variant="@(IsReading ? Variant.Filled : Variant.Outlined)"
                               Color="@(IsReading ? Color.Info : Color.Default)"
                               OnClick="ReadUsersAsync"
                               Disabled="@IsReading"
                               Style="position: relative; overflow: hidden;">
                        @if (IsReading)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            <span>@(_session?.UserReadProgress ?? "Reading…")</span>
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Download" Class="mr-1" />
                            <span>Read Users</span>
                        }
                    </MudButton>
                </MudStack>
            </MudStack>

            @if (_lastResult is not null)
            {
                <MudAlert Severity="@(_lastResult.Success ? Severity.Success : Severity.Error)" Dense="true" Class="mt-3">
                    @if (_lastResult.Success)
                    {
                        <span>Read completed: @_lastResult.ReadCount OK, @_lastResult.FailedCount failed.</span>
                    }
                    else
                    {
                        <span>Read failed: @_lastResult.ErrorMessage</span>
                    }
                </MudAlert>
            }

            @if (IsReading && _session?.UserReadTotal > 0)
            {
                var pct = _session.UserReadTotal > 0
                    ? (double)_session.UserReadCurrent / _session.UserReadTotal * 100
                    : 0;
                <MudProgressLinear Value="@pct" Color="Color.Primary" Rounded="true" Size="Size.Small" Class="mt-2" />
            }
        </MudPaper>

        @if (_session?.Users.Any() == true)
        {
            <div style="overflow-x: auto;">
                <MudSimpleTable Dense="true" Hover="true" FixedHeader="true" Style="max-height: 70vh;">
                    <thead>
                        <tr>
                            <th style="width:50px;">#</th>
                            <th style="min-width:80px;">Status</th>
                            <th style="min-width:150px;">Label</th>
                            <th style="min-width:100px;">Code</th>
                            <th style="min-width:80px;">Type</th>
                            <th>Attributes</th>
                            <th style="min-width:80px;">Partitions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int maxPartitions = _session?.MaxPartitions ?? 2;
                        }
                        @foreach (var item in GetFilteredUsers())
                        {
                            <tr style="@(item.IsActive ? "" : "opacity: 0.4;") cursor: pointer;" @onclick="() => EditUserAsync(item)">
                                <td><strong>@item.UserIndex</strong></td>
                                <td>@GetUserStatusChip(item)</td>
                                <td>@(string.IsNullOrWhiteSpace(item.DisplayLabel) ? "—" : item.DisplayLabel)</td>
                                <td style="font-family: 'Courier New', monospace; font-size: 0.85em;">@FormatCode(item)</td>
                                <td>@GetCodeTypeText(item)</td>
                                <td>
                                    @{
                                        var attrByte = (byte)item.Attributes;
                                        var allZero = attrByte == 0;
                                    }
                                    @if (allZero)
                                    {
                                        <span style="font-family:monospace; font-size:0.8em; white-space:nowrap; opacity:0.3;">00</span>
                                    }
                                    else
                                    {
                                        <MudTooltip Placement="Placement.Left" Arrow="true">
                                            <ChildContent>
                                                <span style="font-family:monospace; font-size:0.8em; white-space:nowrap;">@($"{attrByte:X2}")</span>
                                            </ChildContent>
                                            <TooltipContent>
                                                @RenderAttributeTooltip(item.Attributes)
                                            </TooltipContent>
                                        </MudTooltip>
                                    }
                                </td>
                                <td>
                                    <div style="display: flex; gap: 3px; align-items: center;">
                                        @for (int p = 0; p < maxPartitions; p++)
                                        {
                                            var partNum = (byte)(p + 1);
                                            var assigned = item.Partitions.Contains(partNum);
                                            <div style="width:18px; height:18px; border-radius:50%; display:flex; align-items:center; justify-content:center;
                                                        background:@(assigned ? "#4caf50" : "#9e9e9e"); opacity:@(assigned ? "1" : "0.15");
                                                        font-size:10px; font-weight:bold; color:#fff; line-height:1;"
                                                 title="@($"P{partNum}: {(assigned ? "Assigned" : "Not assigned")}")">@partNum</div>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            </div>
        }
        else if (!IsReading)
        {
            <MudAlert Severity="Severity.Info">No user data loaded yet.</MudAlert>
        }
    }
</MudContainer>

@code {
    private string? _sessionId;
    private SessionState? _session;
    private string? _masterCode;
    private bool _localReading;
    private bool _revealCodes;
    private bool _showInactive;
    private PanelUserReadResult? _lastResult;
    private bool _disposed;
    private bool _renderDirty;
    private Timer? _renderTimer;

    /// <summary>
    /// True if a read is in progress (local or background). Survives page refresh.
    /// </summary>
    private bool IsReading => _localReading || (_session?.IsReadingUsers ?? false);

    protected override void OnInitialized()
    {
        RefreshSession();
        SessionMonitor.SessionsChanged += OnSessionsChanged;
        PanelState.SessionStateChanged += OnSessionStateChanged;

        _renderTimer = new Timer(_ => InvokeAsync(() =>
        {
            if (_disposed || !_renderDirty) return;
            try
            {
                _renderDirty = false;
                _session = _sessionId is null ? null : PanelState.GetSession(_sessionId);
                StateHasChanged();
            }
            catch (ObjectDisposedException) { }
        }), null, 200, 200);
    }

    private void OnSessionsChanged()
    {
        RefreshSession();
        _renderDirty = true;
    }

    private void OnSessionStateChanged(object? sender, SessionStateChangedEventArgs e)
    {
        if (_sessionId == null || !string.Equals(_sessionId, e.SessionId, StringComparison.OrdinalIgnoreCase))
            return;

        _renderDirty = true;
    }

    private void RefreshSession()
    {
        var active = SessionManager.GetActiveSessions().ToList();
        if (_sessionId == null || !active.Contains(_sessionId))
            _sessionId = active.FirstOrDefault();

        _session = _sessionId is null ? null : PanelState.GetSession(_sessionId);
    }

    private async Task ReadUsersAsync()
    {
        if (_sessionId is null || IsReading)
            return;

        var masterCode = await ResolveMasterCodeAsync();
        if (masterCode is null) return;

        _localReading = true;
        _lastResult = null;
        StateHasChanged();

        try
        {
            _lastResult = await UserService.ReadAllAsync(_sessionId, masterCode, CancellationToken.None);
            _session = PanelState.GetSession(_sessionId);

            if (_lastResult.Success)
                Snackbar.Add("User read finished", Severity.Success);
            else
                Snackbar.Add($"User read failed: {_lastResult.ErrorMessage}", Severity.Error);
        }
        finally
        {
            _localReading = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Returns the master code for the current session. Uses the configured value if present;
    /// otherwise prompts the operator via <see cref="AccessCodePromptDialog"/>, which verifies
    /// the code against the panel before closing. Returns null if the operator cancels, in
    /// which case the caller should abort the operation.
    /// </summary>
    private async Task<string?> ResolveMasterCodeAsync()
    {
        // Reuse cached value from a previous verified prompt this page visit.
        if (!string.IsNullOrWhiteSpace(_masterCode))
            return _masterCode;

        // Try connection settings first.
        var configured = ConnectionSettings.CurrentValue.Connections
            .FirstOrDefault(c => string.Equals(c.SessionId, _sessionId, StringComparison.OrdinalIgnoreCase))
            ?.MasterCode;

        if (!string.IsNullOrWhiteSpace(configured))
        {
            _masterCode = configured;
            return _masterCode;
        }

        // Prompt the operator. The dialog verifies against the panel before closing.
        var parameters = new DialogParameters<AccessCodePromptDialog>
        {
            { x => x.Label, "Master Code" },
            { x => x.HelperText, "Enter the panel's master code (4, 6, or 8 digits) to manage user access codes" },
            { x => x.MaxLength, 8 },
            { x => x.InputMode, InputMode.numeric },
            { x => x.Validator, code => IsValidCodeFormat(code) ? null : "Master code must be 4, 6, or 8 digits" },
            { x => x.VerifyAsync, (code, ct) => UserService.VerifyMasterCodeAsync(_sessionId!, code, ct) },
            { x => x.VerificationFailedMessage, "Incorrect master code. Please try again." }
        };

        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
        var dialog = await DialogService.ShowAsync<AccessCodePromptDialog>("Enter Master Code", parameters, options);
        var result = await dialog.Result;

        if (result?.Canceled != false)
        {
            Navigation.NavigateTo("/");
            return null;
        }

        _masterCode = result.Data as string;
        return _masterCode;
    }

    private static bool IsValidCodeFormat(string? code)
    {
        if (string.IsNullOrEmpty(code)) return false;
        if (code.Length != 4 && code.Length != 6 && code.Length != 8) return false;
        foreach (var ch in code)
            if (ch < '0' || ch > '9') return false;
        return true;
    }

    private async Task EditUserAsync(PanelUserState user)
    {
        if (_sessionId is null) return;

        var masterCode = await ResolveMasterCodeAsync();
        if (masterCode is null) return;

        var statusText = user.IsDisabled
            ? " — Disabled"
            : user.IsActive
                ? (user.UserIndex == 1 ? " — Master" : " — Active")
                : " — Empty";

        var parameters = new DialogParameters<UserEditDialog>
        {
            { x => x.User, user },
            { x => x.SessionId, _sessionId },
            { x => x.MaxPartitions, _session?.MaxPartitions ?? 2 },
            { x => x.MasterCode, masterCode }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<UserEditDialog>($"User {user.UserIndex}{statusText}", parameters, options);
        var result = await dialog.Result;
        if (result?.Canceled == false)
        {
            _session = PanelState.GetSession(_sessionId);
            StateHasChanged();
        }
    }

    private IEnumerable<PanelUserState> GetFilteredUsers()
    {
        if (_session == null) return Enumerable.Empty<PanelUserState>();

        var users = _session.Users.Values.OrderBy(x => x.UserIndex);
        return _showInactive ? users : users.Where(x => x.IsActive);
    }

    private string FormatCode(PanelUserState user)
    {
        // Hide the disabled sentinel from the UI — users see the chip, not "AAAA".
        if (user.IsDisabled || string.IsNullOrEmpty(user.CodeValue))
            return "—";
        if (_revealCodes)
            return user.CodeValue;
        return new string('*', Math.Max(4, user.CodeValue.Length));
    }

    private static string GetCodeTypeText(PanelUserState user)
    {
        if (!user.IsActive)
            return "—";

        var parts = new List<string>();
        if (!string.IsNullOrEmpty(user.CodeValue))
            parts.Add("PIN");
        if (user.HasProximityTag)
            parts.Add("Proximity");
        return parts.Count > 0 ? string.Join(" + ", parts) : "—";
    }

    private static RenderFragment RenderAttributeTooltip(PanelUserAttributes attrs) => __builder =>
    {
        <div style="font-size:0.85em; line-height:1.6;">
            <div style="font-weight:600; margin-bottom:2px;">Attributes [@($"0x{(byte)attrs:X2}")]</div>
            @{
                var allFlags = new (PanelUserAttributes flag, string name)[]
                {
                    (PanelUserAttributes.Supervisor,    "Supervisor"),
                    (PanelUserAttributes.DuressCode,    "Duress Code"),
                    (PanelUserAttributes.CanBypassZone, "Can Bypass Zone"),
                    (PanelUserAttributes.RemoteAccess,  "Remote Access"),
                    (PanelUserAttributes.BellSquawk,    "Bell Squawk"),
                    (PanelUserAttributes.OneTimeUse,    "One-Time Use"),
                };
            }
            @foreach (var (flag, name) in allFlags)
            {
                var on = attrs.HasFlag(flag);
                <div style="padding-left:10px;@(on ? "" : " opacity:0.3;")">@name</div>
            }
        </div>
    };

    private static RenderFragment GetUserStatusChip(PanelUserState user) => __builder =>
    {
        if (user.IsDisabled)
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">Disabled</MudChip>;
            return;
        }

        if (!user.IsActive)
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">Empty</MudChip>;
            return;
        }

        var isMaster = user.UserIndex == 1;
        var color = isMaster ? Color.Warning : Color.Success;
        var label = isMaster ? "Master" : "Active";

        <MudChip T="string" Size="Size.Small" Color="@color" Variant="Variant.Filled">@label</MudChip>;
    };

    public void Dispose()
    {
        _disposed = true;
        _renderTimer?.Dispose();
        SessionMonitor.SessionsChanged -= OnSessionsChanged;
        PanelState.SessionStateChanged -= OnSessionStateChanged;
    }
}
