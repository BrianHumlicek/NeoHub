@using NeoHub.Services.PanelConfiguration
@using NeoHub.Services.PanelConfiguration.Sections

<MudDialog>
    <DialogContent>
        <MudStack Spacing="4">
            @* ── LCD Label Preview ── *@
            <MudText Typo="Typo.subtitle2">Partition Label</MudText>
            <div class="lcd-display">
                <div class="lcd-line">@Line1</div>
                <div class="lcd-line">@Line2</div>
            </div>
            <MudTextField T="string"
                          @bind-Value="_label"
                          Label="Label (28 chars max: two 14-char display lines)"
                          MaxLength="28"
                          Variant="Variant.Outlined"
                          Immediate="true"
                          Style="font-family: 'Courier New', monospace;" />

            @* ── Partition Enable ── *@
            <MudSelect T="PartitionEnable"
                       @bind-Value="_enabled"
                       Label="Status"
                       Variant="Variant.Outlined">
                <MudSelectItem T="PartitionEnable" Value="PartitionEnable.Enabled">Enabled</MudSelectItem>
                <MudSelectItem T="PartitionEnable" Value="PartitionEnable.Disabled">Disabled</MudSelectItem>
            </MudSelect>

            @* ── Assigned Zones ── *@
            <MudText Typo="Typo.subtitle2">Assigned Zones (@_assignedZones.Count(z => z))</MudText>
            <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                @for (int z = 0; z < _assignedZones.Length; z++)
                {
                    var idx = z;
                    var zoneNum = z + 1;
                    <MudChip T="string"
                             Size="Size.Small"
                             Variant="@(_assignedZones[idx] ? Variant.Filled : Variant.Outlined)"
                             Color="@(_assignedZones[idx] ? Color.Success : Color.Default)"
                             OnClick="@(() => _assignedZones[idx] = !_assignedZones[idx])">
                        @zoneNum
                    </MudChip>
                }
            </MudStack>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit" Disabled="true">
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

<style>
    .lcd-display {
        background-color: #225cf0;
        border: 3px solid #1a1a2e;
        border-radius: 6px;
        padding: 12px 16px;
        font-family: 'Courier New', Courier, monospace;
        font-size: 18px;
        font-weight: bold;
        letter-spacing: 3px;
        line-height: 1.6;
        color: #e0e8ff;
        text-shadow: 0 0 6px rgba(180, 200, 255, 0.5);
        box-shadow: inset 0 0 12px rgba(0, 0, 0, 0.4);
        min-height: 72px;
    }

    .lcd-line {
        white-space: pre;
        min-height: 1.6em;
    }
</style>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public int PartitionNumber { get; set; }

    [Parameter]
    public PanelConfigurationState Config { get; set; } = null!;

    private string _label = "";
    private PartitionEnable _enabled;
    private bool[] _assignedZones = [];

    private string Line1 => (_label.Length >= 14 ? _label[..14] : _label.PadRight(14)).Replace(' ', '\u00A0');
    private string Line2 => (_label.Length > 14 ? _label[14..Math.Min(28, _label.Length)] : "").PadRight(14).Replace(' ', '\u00A0');

    protected override void OnParametersSet()
    {
        var partIndex = PartitionNumber - 1;
        var partLabels = Config.PartitionLabels.Values;
        var partEnables = Config.PartitionEnables.Values;
        var assignments = Config.ZoneAssignments.Values;
        int maxZones = Config.Capabilities.MaxZones;

        _label = partIndex < partLabels.Count ? (partLabels[partIndex] ?? "") : "";
        _enabled = partIndex < partEnables.Count ? partEnables[partIndex] : PartitionEnable.Disabled;

        _assignedZones = new bool[maxZones];
        for (int z = 0; z < maxZones; z++)
        {
            if (partIndex < assignments.GetLength(0) && z < assignments.GetLength(1))
                _assignedZones[z] = assignments[partIndex, z];
        }
    }

    private void Submit() => MudDialog.Close(DialogResult.Ok(true));
    private void Cancel() => MudDialog.Cancel();
}
